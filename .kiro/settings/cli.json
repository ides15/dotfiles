{
  "app.hideMenubarIcon": true,
  "autocomplete.disable": true,
  "autocomplete.theme": "catppuccin",
  "chat.defaultModel": "claude-opus-4.5",
  "chat.diffTool": "delta",
  "chat.disableAutoCompaction": false,
  "chat.disableMarkdownRendering": false,
  "chat.editMode": "vim",
  "chat.enableCheckpoint": false,
  "chat.enableContextUsageIndicator": true,
  "chat.enableDelegate": true,
  "chat.enableKnowledge": true,
  "chat.enableNotifications": true,
  "chat.enableSubagent": true,
  "chat.enableTangentMode": true,
  "chat.enableThinking": true,
  "chat.enableTodoList": true,
  "chat.greeting.enabled": false,
  "inline.enabled": false,
  "introspect.tangentMode": true,
  "knowledge.defaultExcludePatterns": [
    "**/node_modules/**",
    "**/vendor/**",
    "**/venv/**",
    "**/.venv/**",
    "**/target/**",
    "**/build/**",
    "**/dist/**",
    "**/out/**",
    "**/bin/**",
    "**/obj/**",
    "**/lib/**",
    "**/.git/**",
    "**/__pycache__/**",
    "**/.idea/**",
    "**/.vscode/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/coverage/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/*.min.js",
    "**/*.min.css"
  ],
  "mcp.loadedBefore": true
}

